# Molten local development environment
# Copy to .env and fill in values: cp .env.example .env

# Azure OpenAI (required)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Key Vault (production — not needed for local dev with direct env vars)
# KEY_VAULT_URI=https://your-kv.vault.azure.net/

# Storage (overridden by docker-compose.dev.yml when using Azurite)
STORAGE_ACCOUNT_NAME=devstoreaccount1
QUEUE_NAME=molten-work

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Slack (optional)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Discord (optional)
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# WhatsApp (optional)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# OpenClaw (optional)
OPENCLAW_GATEWAY_URL=
OPENCLAW_MODEL=anthropic/claude-sonnet-4-20250514
